                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"firstName\": \"Wanchai\",\n    \"lastName\": \"User\",\n    \"email\": \"wanchai@test.com\",\n    \"password\": \"123456\",\n    \"gender\": \"male\",\n    \"isVerified\": true\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.token) {",
                                    "    pm.environment.set(\"token\", jsonData.token);",
                                    "}",
                                    "if(jsonData.user && jsonData.user.id) {",
                                    "    pm.environment.set(\"user_id\", jsonData.user.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
